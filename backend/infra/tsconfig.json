{
  "extends": "../../tsconfig.strict.json",
  "compilerOptions": {
    "composite": true,
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": [
      "ES2022"
    ],
    "outDir": "./dist",
    "rootDir": ".",
    "declaration": true,
    "inlineSourceMap": true,
    "inlineSources": true,
    "experimentalDecorators": true,
    "strictPropertyInitialization": false,
    "noUnusedLocals": false,
    "noUnusedParameters": false
  },
  "include": [
    "bin",
    "lib"
  ],
  "exclude": [
    "node_modules",
    "cdk.out",
    "dist",
    "**/*.js",
    "**/*.d.ts"
  ]
}