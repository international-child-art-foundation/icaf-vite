{
  "name": "@icaf/shared",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./api-types/*": {
      "types": "./dist/api-types/*.d.ts",
      "default": "./dist/api-types/*.js"
    },
    "./entities/*": {
      "types": "./dist/entities/*/index.d.ts",
      "default": "./dist/entities/*/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -b",
    "clean": "tsc -b --clean"
  },
  "devDependencies": {
    "prettier": "^3.8.3"
  }
}